# Календарь дашборда и «день» на графике (по умолчанию UTC+8)
TZ=Asia/Shanghai
# CORS (через запятую). В проде добавьте домен, например https://zakroma.cursordm.ru
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173,http://localhost:8080,http://127.0.0.1:8080,https://zakroma.cursordm.ru

# Фронт (Vite): см. frontend/.env.example — VITE_API_BASE для прямых вызовов API без dev-прокси.

# SQLite (локально по умолчанию backend/data/dashboard.db; в Docker — sqlite:////data/dashboard.db)
# DATABASE_URL=sqlite:////data/dashboard.db

# Защита админ-роутов (следующий этап)
# ADMIN_API_KEY=

# Целевой % себестоимости к сумме отгрузок (пока не задан в БД на странице «План»)
# KPI_COST_RATIO_PLAN_PERCENT=38
# Планы для блока доставки/логистики (пока не заданы в БД на странице «План»): факт ≤ план — норма
# KPI_DELIVERY_AVG_PLAN_RUB_PER_KG=45
# KPI_SHIPPING_AVG_PLAN_DAYS=4
# Бонус за задачи и поручения: 0…10 % (10 % = 5 000 ₽ на дашборде; задаётся также в «Установить План»)
# KPI_TASKS_BONUS_PERCENT=0
#
# Планы по месяцам хранятся в SQLite (ключи monthly_plan_YYYY_MM); если для месяца нет записи —
# подставляются глобальные значения выше и эти переменные окружения.

# ==============================
# Источник данных: Google Sheets
# ==============================
# Источник данных для /api/sync: `google_sheets`
KPI_SOURCE=google_sheets

# Снимок KPI (Продажи/Себестоимость/Закупки) обновляется в фоне — дашборд
# открывается мгновенно из БД. Период фонового пересчёта снимка (сек, 60…3600):
# SYNC_REFRESH_SEC=300

# ID Google-таблицы (spreadsheet id из URL).
GOOGLE_SHEETS_SPREADSHEET_ID=1T_WdCgJONWnjMH38HttO6WmE2qxoKoozXBmWYMyihkU

# Имена листов (как в интерфейсе).
GOOGLE_SHEETS_PROFIT_SHEET_NAME=прибыльность
GOOGLE_SHEETS_PURCHASE_SHEET_NAME=Закупка_товары
GOOGLE_SHEETS_RAW_MATERIAL_STOCK_SPREADSHEET_ID=1bFU6x-4qm39wEM356ghETOdeozqTR2RdPRTIJWyAONE
GOOGLE_SHEETS_RAW_MATERIAL_STOCK_SHEET_NAME=Остатки_по_дням
GOOGLE_SHEETS_REORDER_SPREADSHEET_ID=1eUdgokEoZ72xePF8RmQZbuWwoYNuJH9rvU3WvUxBTEE
GOOGLE_SHEETS_REORDER_SHEET_NAME=Остатки сырья
# Важно: встроенный фильтр на листе в Google скрывает строки — gviz отдаёт только видимые; снимите фильтр для полного набора.
# Сырьё в пути (статусы в B, сумма в E)
GOOGLE_SHEETS_IN_TRANSIT_SPREADSHEET_ID=1cNLC0WZVIcHJWQbKYbpbedAdxANDze3VV12Op2F1O3E
GOOGLE_SHEETS_IN_TRANSIT_SHEET_NAME=В ПУТИ
# Доставка/логистика (лист «В ПУТИ» — заказы поставщикам): F — дата оплаты; H, G — суммы; факт ₽/кг = ΣH/ΣG.
# GOOGLE_SHEETS_DELIVERY_COST_SPREADSHEET_ID=1cNLC0WZVIcHJWQbKYbpbedAdxANDze3VV12Op2F1O3E
# GOOGLE_SHEETS_DELIVERY_COST_SHEET_NAME=В ПУТИ

# ==============================
# МойСклад: заказы покупателей (среднее время до отгрузки)
# ==============================
# MOYSKLAD_API_URL=https://api.moysklad.ru/api/remap/1.2
# MOYSKLAD_TOKEN=...   (рекомендуется) или MOYSKLAD_LOGIN + MOYSKLAD_PASSWORD
# KPI: customerorder.created → первая demand.moment (отгрузка)
# Склад розничного магазина: отгрузки с него НЕ входят в среднее время отгрузки
# (совпадение по подстроке в названии склада, регистр/ё не важны). Пусто — не исключать.
# MOYSKLAD_EXCLUDE_SHIPPING_STORE=Магазин
# Комментарий заказа: заказы с этой подстрокой в комментарии НЕ входят в среднее
# время отгрузки (регистр/ё/пробелы не важны). Пусто — не исключать.
# MOYSKLAD_EXCLUDE_ORDER_COMMENT=отсрочка отгрузки
# Среднее время отгрузки кэшируется и обновляется в фоне (расчёт тяжёлый ~10 c).
# Период фонового обновления кэша среднего времени отгрузки (сек, 30…3600):
# SHIPPING_REFRESH_SEC=180

# Backend читает листы публично через gviz: в Google Таблицах — «Все, у кого есть ссылка» (читатель).

# ==============================
# Интеграция задач: YouGile
# ==============================
# URL API вашей компании в YouGile (обычно https://<домен>.yougile.com/api-v2)
YOUGILE_API_URL=
# API-ключ YouGile (Bearer token)
YOUGILE_API_KEY=
# Сотрудник для виджета задач
YOUGILE_EMPLOYEE=Татьяна Живетьева
# Рекомендуется: точный ID сотрудника YouGile (приоритетнее имени)
# YOUGILE_EMPLOYEE_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
#
# Ссылки на задачи в веб-интерфейсе (как «Мои задачи» + #ключ):
# YOUGILE_TASK_LINK_STYLE=my_tasks
# YOUGILE_WEB_LANG=ru
# Если API отдаёт чужой url — собрать ссылку сами: YOUGILE_TASK_IGNORE_API_URL=1
#
# Таймаут HTTPS к YouGile (сек, по умолчанию 45) и повторы при обрыве/TLS (по умолчанию 2):
# YOUGILE_HTTP_TIMEOUT=45
# YOUGILE_HTTP_RETRIES=2
#
# Задачи кэшируются в памяти и обновляются в фоне — дашборд открывается мгновенно.
# Период фонового обновления кэша задач сотрудника по умолчанию (сек, 20…3600):
# YOUGILE_REFRESH_SEC=90
