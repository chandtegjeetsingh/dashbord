# Календарь дашборда и «день» на графике (по умолчанию UTC+8)
TZ=Asia/Shanghai
# CORS для локальной разработки (через запятую)
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173,http://localhost:8080,http://127.0.0.1:8080

# SQLite (локально по умолчанию backend/data/dashboard.db; в Docker — sqlite:////data/dashboard.db)
# DATABASE_URL=sqlite:////data/dashboard.db

# Защита админ-роутов (следующий этап)
# ADMIN_API_KEY=

# ==============================
# Источник данных: Google Sheets
# ==============================
# Источник данных для /api/sync: `google_sheets`
KPI_SOURCE=google_sheets

# ID Google-таблицы (spreadsheet id из URL).
GOOGLE_SHEETS_SPREADSHEET_ID=1T_WdCgJONWnjMH38HttO6WmE2qxoKoozXBmWYMyihkU

# Имена листов (как в интерфейсе).
GOOGLE_SHEETS_PROFIT_SHEET_NAME=прибыльность
GOOGLE_SHEETS_PURCHASE_SHEET_NAME=Закупка_товары
GOOGLE_SHEETS_RAW_MATERIAL_STOCK_SPREADSHEET_ID=1bFU6x-4qm39wEM356ghETOdeozqTR2RdPRTIJWyAONE
GOOGLE_SHEETS_RAW_MATERIAL_STOCK_SHEET_NAME=Остатки_по_дням
GOOGLE_SHEETS_REORDER_SPREADSHEET_ID=1eUdgokEoZ72xePF8RmQZbuWwoYNuJH9rvU3WvUxBTEE
GOOGLE_SHEETS_REORDER_SHEET_NAME=Остатки сырья
# Сырьё в пути (статусы в B, сумма в E)
GOOGLE_SHEETS_IN_TRANSIT_SPREADSHEET_ID=1cNLC0WZVIcHJWQbKYbpbedAdxANDze3VV12Op2F1O3E
GOOGLE_SHEETS_IN_TRANSIT_SHEET_NAME=В ПУТИ

# Backend читает листы публично через gviz: в Google Таблицах — «Все, у кого есть ссылка» (читатель).

# ==============================
# Интеграция задач: YouGile
# ==============================
# URL API вашей компании в YouGile (обычно https://<домен>.yougile.com/api-v2)
YOUGILE_API_URL=
# API-ключ YouGile (Bearer token)
YOUGILE_API_KEY=
# Сотрудник для виджета задач
YOUGILE_EMPLOYEE=Татьяна Живетьева
# Рекомендуется: точный ID сотрудника YouGile (приоритетнее имени)
# YOUGILE_EMPLOYEE_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
