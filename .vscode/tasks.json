{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Frontend: Vite dev",
      "type": "shell",
      "command": "npm run dev",
      "options": {
        "cwd": "${workspaceFolder}/frontend",
        "env": {
          "PATH": "/opt/homebrew/bin:/usr/local/bin:${env:PATH}"
        },
        "shell": {
          "executable": "/bin/zsh",
          "args": ["-il", "-c"]
        }
      },
      "isBackground": true,
      "problemMatcher": {
        "owner": "vite",
        "pattern": { "regexp": "^$" },
        "background": {
          "activeOnStart": true,
          "beginsPattern": "VITE",
          "endsPattern": "Local:\\s+http://localhost:5173"
        }
      },
      "group": {
        "kind": "build",
        "isDefault": false
      }
    }
  ]
}
